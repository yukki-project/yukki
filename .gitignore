# Build artifacts
/yukki
/yukki.exe
/dist/
/bin/

# Local Go cache and tempdir (used by scripts/dev/* to keep build artifacts
# inside the repo rather than %TEMP% — see DEVELOPMENT.md for the rationale,
# typically Windows AV blocking exec from %TEMP%).
/.gocache/
/.gotmp/

# IDE
/.idea/
/.vscode/

# Test artifacts
*.test
*.out
coverage.txt
coverage.html

# OS
.DS_Store
Thumbs.db

# Local-only working docs (vision drafts, scratch notes — not committed)
/VISION.md
/notes/

# SPDD research review — local-only working corpus, not committed
# (~50 000 mots produits par 14 agents Claude pour préparer SPDD v2 ;
# matériel de réflexion personnel, ne doit pas vivre dans l'historique
# du dépôt).
/.yukki/research/

# PDF locaux générés depuis du markdown — sources versionnées, pas
# les rendus.
*.pdf

# Wails / frontend artefacts
/frontend/node_modules/
# Vite build output. Keep .gitkeep so //go:embed all:frontend/dist
# succeeds in static-checks CI before any wails build has run.
/frontend/dist/*
!/frontend/dist/.gitkeep
# Auto-generated Wails bindings — committed as minimal stubs.
#
# Wails 2.12 reports "Generating bindings: Done" but skips regen
# silently when the directory already exists (cache check). On a
# fresh clone (CI runner), `wails build` triggers regen and would
# overwrite. On a local dev machine where Defender quarantines the
# Wails helper binary in %TEMP% (cf. TICKET IT in TODO.md), regen
# fails silently and the committed stubs are what tsc + Vite/rollup
# resolve against.
#
# Both .d.ts (types for tsc) and .js (runtime for Vite/rollup) are
# committed. They are tiny (4-line Greet wrapper + minimal runtime).
# Wails idempotent regen overwrites them when it does run; the
# committed version is the post-regen state from the last successful
# binding generation.
#
# Nothing in wailsjs/ is ignored except node_modules-style noise.
/frontend/wailsjs/**/node_modules/
# Wails binary output only — `build/appicon.png`, `build/windows/icon.ico`,
# `build/windows/info.json`, `build/windows/wails.exe.manifest` are SOURCES
# (configurées par wails.json + utilisées par `wails build`) et restent
# trackées. Seul le binaire généré dans `build/bin/` est ignoré.
/build/bin/

# Wails / frontend caches written by `wails build` next to package.json:
# md5 stamp file used to detect package.json changes, TS build-info,
# and the JS-compiled vite.config (we keep vite.config.ts as source).
/frontend/package.json.md5
/frontend/*.tsbuildinfo
/frontend/vite.config.d.ts
/frontend/vite.config.js
